# SHMTU OCR Server Docker settings
#
# Usage:
# 1. Copy this file to .env
# 2. Run from repository root:
#    docker compose up -d
#
# GPU:
#    OCR_VARIANT=latest-gpu docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d

# Default image repository: Alibaba Cloud Container Registry
IMAGE_REPOSITORY=registry.cn-shanghai.aliyuncs.com/a645162/shmtu-ocr-server

OCR_VARIANT=latest

# Build-time options, used only when running `docker compose build`
BUILD_TARGET=runtime-cpu
USE_GPU=false

# Published ports
HTTP_PORT=21600
TCP_PORT=21601

# Runtime options
EXECUTION_PROVIDER=CPU
GPU_DEVICE_ID=0
