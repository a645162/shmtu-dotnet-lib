# OCR Server Docker 配置
#
# 使用方式：
#
# 1. CPU 版本（默认）：
#    docker compose up -d
#
# 2. GPU 版本：
#    OCR_VARIANT=latest-gpu docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
#
# 可配置变量：

# 镜像标签（决定使用 CPU 还是 GPU 镜像）
OCR_VARIANT=latest

# 构建参数（仅 docker compose build 时生效）
BUILD_TARGET=runtime-cpu
USE_GPU=false

# 端口映射
HTTP_PORT=21600
TCP_PORT=21601

# 推理执行提供者（CPU 或 CUDA）
EXECUTION_PROVIDER=CPU
GPU_DEVICE_ID=0
