<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:shmtu.captcha.onnx.gui.ViewModels"
        mc:Ignorable="d"
        x:Class="shmtu.captcha.onnx.gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980" Height="720" MinWidth="820" MinHeight="600"
        Title="上海海事大学统一认证平台 验证码 OCR (ONNX · Avalonia)">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #1A000000"/>
        </Style>
        <Style Selector="Border.card-inner">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.section-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="TextBlock.dim-text">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
    </Window.Styles>

    <DockPanel Margin="12">

        <!-- 顶部：模型状态 + 下载进度 -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="模型目录：" VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBox Text="{Binding ModelDirectory}" Width="520" VerticalAlignment="Center"/>
                    <Button Content="检查 / 下载模型"
                            Command="{Binding EnsureModelsCommand}"
                            VerticalAlignment="Center"/>
                    <Border Padding="10,4" CornerRadius="12" VerticalAlignment="Center"
                            Background="{DynamicResource SystemAccentColorBrush}">
                        <TextBlock Text="{Binding ModelStatusText}"
                                   Foreground="{DynamicResource SystemControlForegroundChromeWhiteBrush}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <ProgressBar Minimum="0" Maximum="100" Height="6"
                             Value="{Binding DownloadProgress}"/>
            </StackPanel>
        </Border>

        <!-- 底部：状态栏 -->
        <Border DockPanel.Dock="Bottom" Classes="card" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Border>

        <!-- 中部：左大图 + 大字结果，右按钮列；下方可折叠批量区 -->
        <Grid RowDefinitions="*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="*,240">

                <!-- 左：图片预览 + 大字结果 -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,10,0">
                    <DockPanel>
                        <!-- 大字结果（底部） -->
                        <Border DockPanel.Dock="Bottom" Classes="card-inner"
                                Padding="14,10" Margin="0,10,0,0">
                            <StackPanel Orientation="Vertical" Spacing="2">
                                <TextBlock Text="识别结果" Classes="dim-text"/>
                                <TextBlock Text="{Binding ResultExpr}"
                                           FontSize="34" FontWeight="Bold"
                                           Foreground="{DynamicResource SystemAccentColorBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Classes="dim-text">
                                    <Run Text="用时："/>
                                    <Run Text="{Binding CurrentElapsedMs}"/>
                                    <Run Text=" 毫秒"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <!-- 来源 -->
                        <TextBlock DockPanel.Dock="Bottom" Margin="2,6,2,0"
                                   Text="{Binding CurrentSource}"
                                   Classes="dim-text"
                                   TextTrimming="CharacterEllipsis"/>
                        <!-- 图片预览 -->
                        <Border Classes="card-inner" Padding="4">
                            <Image Source="{Binding CurrentPreview}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- 右：操作按钮列 -->
                <Border Grid.Column="1" Classes="card">
                    <StackPanel Orientation="Vertical" Spacing="10">

                        <TextBlock Text="获取图片" Classes="section-label"/>
                        <TextBox Text="{Binding CaptchaUrl}"
                                 PlaceholderText="验证码 URL"/>
                        <Button Content="下载验证码"
                                HorizontalAlignment="Stretch"
                                FontSize="16"
                                Command="{Binding DownloadFromCasCommand}"/>
                        <Button Content="打开本地图片"
                                HorizontalAlignment="Stretch"
                                FontSize="16"
                                Command="{Binding OpenLocalCommand}"/>

                        <Separator Margin="0,6,0,6"/>

                        <TextBlock Text="识别" Classes="section-label"/>
                        <Button Content="▶ OCR 识别"
                                HorizontalAlignment="Stretch"
                                FontSize="20" FontWeight="Bold"
                                Padding="0,12"
                                Background="{DynamicResource SystemAccentColorBrush}"
                                Foreground="{DynamicResource SystemControlForegroundChromeWhiteBrush}"
                                Command="{Binding RecognizeCommand}"/>

                        <Separator Margin="0,6,0,6"/>

                        <TextBlock Text="批量" Classes="section-label"/>
                        <Button Content="加入批量列表"
                                HorizontalAlignment="Stretch"
                                Command="{Binding AddToBatchCommand}"/>

                        <Separator Margin="0,6,0,6"/>

                        <Button Content="释放模型"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ReleaseModelCommand}"/>

                        <TextBlock Text="Author: Haomin Kong"
                                   FontSize="10"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 下方：可展开的批量识别区 -->
            <Expander Grid.Row="1" Margin="0,10,0,0" Header="批量识别 / 批量比对">
                <Border Classes="card">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                            <Button Content="选择多张本地图片..."
                                    Command="{Binding SelectFilesCommand}"/>
                            <Button Content="批量识别"
                                    Background="{DynamicResource SystemAccentColorBrush}"
                                    Foreground="{DynamicResource SystemControlForegroundChromeWhiteBrush}"
                                    Command="{Binding RecognizeAllCommand}"/>
                            <Button Content="清空列表"
                                    Command="{Binding ClearCommand}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                                <Run Text="共 "/>
                                <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                                <Run Text=" 项 · 平均 "/>
                                <Run Text="{Binding AverageMs, StringFormat={}{0:F1}}"/>
                                <Run Text=" 毫秒"/>
                            </TextBlock>
                        </StackPanel>

                        <ScrollViewer MaxHeight="220">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:CaptchaItemViewModel">
                                        <Border Classes="card-inner" Padding="8" Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="120,*,Auto">
                                                <Border Grid.Column="0" Width="110" Height="44"
                                                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                                        CornerRadius="4" Padding="2">
                                                    <Image Source="{Binding Preview}" Stretch="Uniform"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                                            VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Source}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Classes="dim-text"/>
                                                    <TextBlock Text="{Binding Expr}"
                                                               FontSize="16" FontWeight="Bold"
                                                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                            HorizontalAlignment="Right" Spacing="2">
                                                    <TextBlock Text="{Binding Status}"
                                                               HorizontalAlignment="Right"
                                                               Classes="dim-text"/>
                                                    <TextBlock HorizontalAlignment="Right" Classes="dim-text">
                                                        <Run Text="{Binding ElapsedMs}"/>
                                                        <Run Text=" ms"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Expander>
        </Grid>

    </DockPanel>
</Window>
